{
  "name": "@paperclipai/orager",
  "version": "0.0.1",
  "private": true,
  "description": "OpenRouter agentic CLI for Paperclip agent loops",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "orager": "./dist/index.js",
    "orager-mcp": "./dist/mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "build:ui": "vite build --config ui/vite.config.ts",
    "build:all": "npm run build && npm run build:ui",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "node node_modules/vitest/vitest.mjs run --config vitest.config.ts",
    "test:watch": "node node_modules/vitest/vitest.mjs --config vitest.config.ts",
    "test:coverage": "node node_modules/vitest/vitest.mjs run --coverage --config vitest.config.ts",
    "dev": "tsx src/index.ts",
    "dev:ui": "vite --config ui/vite.config.ts",
    "mcp": "tsx src/mcp.ts"
  },
  "devDependencies": {
    "@tanstack/react-virtual": "^3.13.23",
    "@types/node": "^24.6.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/split2": "^4.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.3.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sqlite.org/sqlite-wasm": "^3.51.2-build8",
    "gpt-tokenizer": "^3.4.0",
    "split2": "^4.2.0"
  }
}
